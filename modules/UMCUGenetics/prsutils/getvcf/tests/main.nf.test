nextflow_process {
    name "Test Process PRSUTILS_GETVCF"
    script "../main.nf"
    process "PRSUTILS_GETVCF"


    tag "modules"
    tag "modules/local"
    tag "local"
    tag "normalisation"
    tag "modules/PRSUTILS_GETVCF"

    test("Test BCAC_313 SNP VCF") {

        when{
            process {
                """
                input[0] = [
                    [id: "BCAC_313"],
                    file(params.modules_umcu_testdata_base_path + "pgscatalog/BCAC_313_PRS_GRCh38.txt",
                        checkifExists: true)
                ]
                input[1] = Channel.value("GRCh38")
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.list ,
                    process.out.findAll { key, val -> key.startsWith('versions') }
                  ).match() }
            )
        }
    }
}
