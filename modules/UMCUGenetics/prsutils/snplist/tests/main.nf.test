nextflow_process {
    name "Test Process SNPlist"
    script "../main.nf"
    process "PRSUTILS_SNPLIST"


    tag "modules"
    tag "modules/UMCUGenetics"
    tag "normalisation"

    test("Test BCAC_313 SNP list") {

        when {
            process {
                """
                input[0] = [
                    [id: "BCAC_313"],
                    file(params.modules_umcu_testdata_base_path + "pgscatalog/BCAC_313_PRS_GRCh38.txt",
                    checkifExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.list,
                    process.out.findAll { key, val -> key.startsWith('versions') }
                  ).match() }
            )
        }
    }
}
