nextflow_process {

    name "Test Process PLINK2_SCOREEXPANDED"
    script "../main.nf"
    process "PLINK2_SCOREEXPANDED"


    tag "modules"
    tag "modules_nfcore"
    tag "plink2"
    tag "plink2/scoreexpanded"
    tag "plink2/vcfexpanded"

    test("plink2_score") {
        config "./nextflow.config"
        setup {
            run("PLINK2_VCFEXPANDED") {
                script "../../vcfexpanded/main.nf"
                process {
                        """
                    input[0] = [
                        [ id: 'test', single_end:false ],
                        [
                            file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/vcf/syntheticvcf_short.vcf.gz', checkIfExists: true)
                        ]
                    ]
                    """
                }
            }
        }

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                sfile= channel.value(file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/vcf/syntheticvcf_short.score', checkIfExists: true))
                ch = PLINK2_VCFEXPANDED.out.pgen
                    .concat(PLINK2_VCFEXPANDED.out.psam, PLINK2_VCFEXPANDED.out.pvar, PLINK2_VCFEXPANDED.out.afreq)
                    .groupTuple()
                    .map{ it.flatten() }
                    .combine(sfile)
                input[0] = ch
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert process.out.score.get(0).get(1) ==~ ".*.sscore" },
                { assert snapshot(process.out.versions).match("versions") },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
