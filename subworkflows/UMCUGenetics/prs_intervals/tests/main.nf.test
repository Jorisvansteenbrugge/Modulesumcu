nextflow_workflow {
    name "Test Subworkflow PRS intervals"
    script "../main.nf"
    config "./nextflow.config"
    workflow "PRS_INTERVALS"

    tag "subworkflows"
    tag "subworkflows_UMCUGenetics"
    tag "subworkflows/prs_intervals"
    tag "prs_intervals"
    tag "pgscatalog/combine"
    tag "../../../modules/nf-core/bcftools/sort"
    tag "prs_utils/snplist"
    tag "prs_utils/gatk_vcf"

    setup{
        nfcoreInitialise("${launchDir}/library/")
        nfcoreInstall(
            "${launchDir}/library/",
            [
                "bcftools/sort"
            ]
        )
        nfcoreLink("${launchDir}/library/", "${baseDir}/modules/")
    }

    test("Validate PRS interval creation") {

        when {
            workflow{
                """
                input[0] = channel.of([
                    [id: "BCAC_313_PRS_GRCh38"],
                    file(params.modules_umcu_testdata_base_path + "pgscatalog/BCAC_313_PRS_GRCh38.txt",
                    checkifExists: true)
                ])
                input[1] = Channel.value("GRCh38")
                """
            }
        }

        then {
            assertAll(
               { assert workflow.success },
               { assert snapshot(
                    workflow.out.vcf,
                    workflow.out.list,
                    workflow.out.normalised_model
                 ).match() }
            )
        }
        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/")
        }
    }


}
