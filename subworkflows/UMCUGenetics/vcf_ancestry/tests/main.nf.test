nextflow_workflow {
    name "Test Ancestry subworkflow"
    script "../main.nf"
    config "./nextflow.config"
    workflow "VCF_ANCESTRY"

    tag "subworkflows"
    tag "ancestry/merge"
    tag "plink2/extract"
    tag "subworkflows_UMCUGenetics"
    tag "subworkflows/vcf_ancestry"
    tag "subworkflows/../../modules/nf-core/bcftools/view"
    tag "subworkflows/../../modules/nf-core/plink2/pca"
    tag "subworkflows/../../modules/nf-core/bcftools/merge"
    tag "subworkflows/../../modules/nf-core/plink2/indeppairwise"
    tag "plink2/vcfexpanded"
    tag "ancestry/calc"

    tag "ancestry"
    tag "local"

    setup{
        nfcoreInitialise("${launchDir}/library/")
        nfcoreInstall(
            "${launchDir}/library/",
            [
                "bcftools/view",
                "bcftools/merge",
                "plink2/pca",
                "plink2/indeppairwise"
            ]
        )
        nfcoreLink("${launchDir}/library/", "${baseDir}/modules/")
    }

    test("Validate ancestry subworkflow") {

        when {
            workflow{
                """
                input[0] = Channel.of([
                    [id: 'test_sample'],
                    file(params.subworkflows_umcu_testdata_base_path + "vcf_ancestry/test_sample.vcf.gz", checkIfExists: true),
                    file(params.subworkflows_umcu_testdata_base_path + "vcf_ancestry/test_sample.vcf.gz.tbi", checkIfExists: true)
                ])
                input[1] = Channel.of([
                    [id: 'test_ref'],
                    file(params.subworkflows_umcu_testdata_base_path + "vcf_ancestry/test_ref.vcf.gz", checkIfExists: true),
                    file(params.subworkflows_umcu_testdata_base_path + "vcf_ancestry/test_ref.vcf.gz.tbi", checkIfExists: true)
                ]).first()
                input[2] = Channel.of([
                    [id: 'ref_meta'],
                    file(params.subworkflows_umcu_testdata_base_path + "vcf_ancestry/test_ref_meta.psam", checkIfExists: true)
                ])
                input[3] = Channel.of([
                    [id: 'genome'],
                    file("genome.fasta") //dummy fasta
                ])
                input[4] = Channel.of([
                    [id: 'genome'],
                    file("genome.fasta.fai") //dummy fasta index
                ])
                """
            }
        }
        then{
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out.knn_tsv).match()}
            )
        }
        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/")
        }
    }

    test("Validate ancestry subworkflow with multiple samples") {
        // The single-sample test above passes even when the regions files are collected across
        // samples instead of joined per sample; only a fan-out catches that.
        // The same VCF is reused under two metas, so no extra test data is needed.

        when {
            workflow{
                """
                input[0] = Channel.of(
                    [
                        [id: 'test_sample_a'],
                        file(params.subworkflows_umcu_testdata_base_path + "vcf_ancestry/test_sample.vcf.gz", checkIfExists: true),
                        file(params.subworkflows_umcu_testdata_base_path + "vcf_ancestry/test_sample.vcf.gz.tbi", checkIfExists: true)
                    ],
                    [
                        [id: 'test_sample_b'],
                        file(params.subworkflows_umcu_testdata_base_path + "vcf_ancestry/test_sample.vcf.gz", checkIfExists: true),
                        file(params.subworkflows_umcu_testdata_base_path + "vcf_ancestry/test_sample.vcf.gz.tbi", checkIfExists: true)
                    ]
                )
                input[1] = Channel.of([
                    [id: 'test_ref'],
                    file(params.subworkflows_umcu_testdata_base_path + "vcf_ancestry/test_ref.vcf.gz", checkIfExists: true),
                    file(params.subworkflows_umcu_testdata_base_path + "vcf_ancestry/test_ref.vcf.gz.tbi", checkIfExists: true)
                ]).first()
                input[2] = Channel.of([
                    [id: 'ref_meta'],
                    file(params.subworkflows_umcu_testdata_base_path + "vcf_ancestry/test_ref_meta.psam", checkIfExists: true)
                ])
                input[3] = Channel.of([
                    [id: 'genome'],
                    file("genome.fasta") //dummy fasta
                ])
                input[4] = Channel.of([
                    [id: 'genome'],
                    file("genome.fasta.fai") //dummy fasta index
                ])
                """
            }
        }
        then{
            assertAll(
                { assert workflow.success },
                { assert workflow.out.knn_tsv.size() == 2 },
                { assert snapshot(workflow.out.knn_tsv.sort{ entry -> entry[0].id }).match()}
            )
        }
        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/")
        }
    }
}
